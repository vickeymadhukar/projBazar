# ============================================================
#  ProjBazaar — Backend Environment Variables
#  Fill in your values — this file is committed to git as a template
#  Create a copy named .env with your actual credentials
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Frontend URL (for CORS + Google OAuth redirect) ──────────
FRONTEND_URL=http://localhost:5173

# ── MongoDB Atlas ────────────────────────────────────────────
# Get this from: MongoDB Atlas → Connect → Drivers → Node.js
# Replace <username>, <password>, <cluster> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/projbazaar?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Redis (Upstash) ───────────────────────────────────────────
# Get from: upstash.com → Create Database → Redis → REST URL (use ioredis URL)
# Local dev: redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ── Cloudinary ────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
